{
  "name": "supacommerce",
  "version": "0.7.0",
  "private": true,
  "description": "supacommerce monorepo — ecommerce building blocks for Supabase",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @supacommerce/cli build",
    "build:client": "pnpm --filter @supacommerce/client build",
    "build:utils": "pnpm --filter @supacommerce/utils build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "publish:all": "pnpm publish -r --access public",
    "install:dashboard": "pnpm install --filter dashboard",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "build:dashboard": "pnpm --filter dashboard build",
    "preview:dashboard": "pnpm --filter dashboard serve",
    "type-check:dashboard": "pnpm --filter dashboard type-check",
    "lint:dashboard": "pnpm --filter dashboard lint",
    "format:dashboard": "pnpm --filter dashboard format",
    "add:dashboard": "pnpm add --filter dashboard",
    "remove:dashboard": "pnpm remove --filter dashboard",
    "exec:dashboard": "pnpm --filter dashboard exec"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
