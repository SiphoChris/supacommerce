{
  "name": "@supacommerce/cli",
  "version": "0.23.0",
  "description": "CLI for supacommerce — initialise your ecommerce backend with one command",
  "license": "MIT",
  "type": "module",
  "bin": {
    "supacommerce": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.18.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
